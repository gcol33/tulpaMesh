Package: tulpaMesh
Title: Constrained Delaunay Triangulation Meshes for Spatial 'SPDE' Models
Version: 0.1.1
Authors@R: c(
    person("Gilles", "Colling", email = "gilles.colling051@gmail.com",
           role = c("aut", "cre", "cph"),
           comment = c(ORCID = "0000-0003-3070-6066")),
